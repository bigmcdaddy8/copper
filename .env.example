# Tradier API credentials
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Production API key (from your Tradier brokerage account settings)
TRADIER_API_KEY=your_production_api_key_here

# Sandbox API key (from your Tradier paper-trading account settings)
TRADIER_SANDBOX_API_KEY=your_sandbox_api_key_here

# Active environment: "production" or "sandbox" (default: production)
# Override on the CLI with --sandbox
TRADIER_ENV=production
